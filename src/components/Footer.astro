---
import { Image } from "astro:assets";
import tiktokIcon from "@assets/logos/tiktok-logo.svg";
import xIcon from "@assets/logos/x-logo.svg";
import instagramIcon from "@assets/logos/instagram-logo.svg";
import youtubeIcon from "@assets/logos/youtube-logo.svg";

const iconClasses = "w-auto h-9 md:h-12";
---

<footer class="mt-6">
    <!-- Social media link icons -->
    <div class="flex justify-center gap-8">
        <a
            href="https://www.tiktok.com/@revistafan"
            target="_blank"
            rel="noopener noreferrer"
        >
            <Image src={tiktokIcon} alt="TikTok" class={iconClasses} />
        </a>
        <a
            href="https://x.com/fanrevista"
            target="_blank"
            rel="noopener noreferrer"
        >
            <Image src={xIcon} alt="X" class={iconClasses} />
        </a>
        <a
            href="https://www.instagram.com/fanrevista"
            target="_blank"
            rel="noopener noreferrer"
        >
            <Image src={instagramIcon} alt="Instagram" class={iconClasses} />
        </a>
        <a
            href="https://youtube.com/@revistafan"
            target="_blank"
            rel="noopener noreferrer"
        >
            <Image src={youtubeIcon} alt="YouTube" class={iconClasses} />
        </a>
    </div>
    <!-- Footer copyright notice -->
    <p class="mt-8 p-4 text-center text-sm text-white">
        &copy;2019, {new Date().getFullYear()} Revista Fan.<br>TODOS LOS DERECHOS RESERVADOS
    </p>
</footer>
