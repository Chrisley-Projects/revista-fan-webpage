<div class="mx-auto w-3/4 max-w-3xl text-white md:w-1/2">
    <!-- Etiquetas 0% / 100% -->
    <div class="mb-2 flex justify-between text-sm tabular-nums">
        <span>0%</span>
        <span>100%</span>
    </div>

    <!-- Pista -->
    <div
        class="relative h-6 overflow-hidden rounded-full bg-linear-to-r from-neutral-600 via-neutral-700 to-neutral-700/80"
    >
        <!-- Relleno: anima 0% -> 50%, borde derecho recto -->
        <div
            class="animate-progress h-full w-0 overflow-hidden rounded-l-full rounded-r-none"
        >
            <div class="relative h-full">
                <div class="h-full w-full progress-gradient rounded-l-full"></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Animación solo CSS: 0% -> 50% */
    @keyframes progress {
        from {
            width: 0%;
        }
        to {
            width: 50%;
        }
    }
    .animate-progress {
        animation: progress 1s linear forwards;
    }

    .progress-gradient {
        background: linear-gradient(135deg, #00aeef, #ec008c,#ffd93f);
    }

    /* Respeta reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .animate-progress {
            animation: none;
            width: 50%;
        }
    }
</style>
