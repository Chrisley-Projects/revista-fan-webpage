---

---

<div class="mx-auto w-3/4 max-w-3xl text-white md:w-1/2">
    <!-- Etiquetas 0% / 100% -->
    <div class="mb-2 flex justify-between text-sm tabular-nums">
        <span>0%</span>
        <span>100%</span>
    </div>

    <!-- Pista -->
    <div
        class="relative h-6 overflow-hidden rounded-full bg-gradient-to-r from-neutral-600 via-neutral-700 to-neutral-700/80"
    >
        <!-- Relleno: anima 0% -> 50%, borde derecho recto -->
        <div
            class="animate-progress h-full w-0 overflow-hidden rounded-l-full rounded-r-none"
        >
            <div class="relative flex h-full">
                <!-- Cian (diagonal al final) -->
                <div class="relative h-full basis-1/3 bg-[#06AEEF]">
                    <!-- cuña para corte diagonal -->
                    <div
                        class="absolute top-0 right-[-16px] h-full w-8 skew-x-12 bg-[#06AEEF]"
                    >
                    </div>
                </div>

                <!-- Magenta (diagonal al final) -->
                <div class="relative h-full basis-1/3 bg-[#EC008C]">
                    <div
                        class="absolute top-0 right-[-16px] h-full w-8 skew-x-12 bg-[#EC008C]"
                    >
                    </div>
                </div>

                <!-- Amarillo (final recto) -->
                <div class="relative h-full basis-1/3 bg-[#FFD93F]"></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Animación solo CSS: 0% -> 50% */
    @keyframes progress {
        from {
            width: 0%;
        }
        to {
            width: 50%;
        }
    }
    .animate-progress {
        animation: progress 1s linear forwards;
    }

    /* Respeta reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .animate-progress {
            animation: none;
            width: 50%;
        }
    }
</style>
